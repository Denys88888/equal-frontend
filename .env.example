# Equal Frontend Environment Variables
# Copy to .env and fill in your values

# Pi Network Configuration
VITE_PI_APP_ID=your_pi_app_id_here
VITE_PI_SANDBOX=false

# Backend API URL (when backend is ready)
VITE_API_URL=https://api.equal.app/v1

# WebSocket URL (when backend is ready)
VITE_WS_URL=wss://api.equal.app/v1/ws

# Feature Flags
VITE_ENABLE_VIDEO_CALLS=true
VITE_ENABLE_B2B_OFFERS=true
VITE_ENABLE_ADMIN_PANEL=true

# Optional: Analytics
# VITE_ANALYTICS_ID=
